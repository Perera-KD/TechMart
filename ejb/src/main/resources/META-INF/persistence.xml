<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">
    <persistence-unit name="TechMartPU" transaction-type="JTA">
        <jta-data-source>java:app/jdbc/TechMartDS</jta-data-source>
        <class>org.techmart.lk.core.entity.User</class>
        <class>org.techmart.lk.core.entity.Product</class>
        <class>org.techmart.lk.core.entity.Warehouse</class>
        <class>org.techmart.lk.core.entity.Order</class>
        <class>org.techmart.lk.core.entity.OrderItem</class>
        <class>org.techmart.lk.core.entity.AuditLog</class>
        <exclude-unlisted-classes>true</exclude-unlisted-classes>
        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="eclipselink.ddl-generation" value="drop-and-create-tables"/>
            <property name="eclipselink.ddl-generation.output-mode" value="database"/>
            <property name="eclipselink.logging.level" value="FINE"/>
        </properties>
    </persistence-unit>
</persistence>
